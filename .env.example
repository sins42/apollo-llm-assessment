# PostgreSQL connection string.
# Format: postgresql://username:password@localhost/database_name
# If no password: postgresql://username@localhost/database_name
# Find your username by running: psql -U postgres -c "\du"
DATABASE_URL=postgresql://username:password@localhost/apollo_exercises

# Get your free API key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here